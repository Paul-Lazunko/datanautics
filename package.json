    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": "10.5.0",
    "husky": "9.1.7",
    "prettier": "3.8.4",
    "prettier-plugin-multiline-arrays": "4.1.9",
    "tsc-alias": "1.8.17",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:databikers/datanautics.git"
  },
