    "test": "node test/test.cjs",
    "prepare": "husky",
    "runtime": "node dist/index.js"
  },
  "dependencies": {
    "property-accessor": "^2.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "24.13.1",
